# ============================================
# Railway 环境变量配置
# ============================================

# MySQL 数据库连接（在 Railway Dashboard 中手动设置）
# 格式: jdbc:mysql://<host>:<port>/<db>?useSSL=true&serverTimezone=UTC
JDBC_DATABASE_URL=jdbc:mysql://localhost:3306/meal_planner?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true

# MySQL 用户（Railway MySQL 插件自动注入）
MYSQL_USER=root

# MySQL 密码（Railway MySQL 插件自动注入）
MYSQL_PASSWORD=123456

# AI API Key（可选，不配置则使用本地规则规划器）
AI_API_KEY=sk-your-api-key-here
